# Copy to .env and fill in. The two credentials you must provide:
#   1) GOOGLE_API_KEY  — a Google AI Studio key (https://aistudio.google.com/apikey)
#   2) secrets/gcp.json — a BigQuery service-account key (see secrets/README.md)

# Gemini (LLM + embeddings).
GOOGLE_API_KEY=your-ai-studio-key
GEMINI_MODEL=gemini-3.5-flash
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=768

# BigQuery — billing project + SA key path (inside the container).
GOOGLE_CLOUD_PROJECT=opsfleettest
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp.json

# Postgres (compose overrides host to `postgres`; host runs use 5435).
DATABASE_URL=postgresql://retail:retail@localhost:5435/retail

# Tunables.
MAX_SQL_ATTEMPTS=2
MAX_RESULT_ROWS=1000
PREVIEW_ROWS=50
MODEL_RUN_LIMIT=12
RETRIEVAL_TOP_K=3

# Identity + idempotency.
AGENT_USER_ID=manager_a
HMAC_SECRET=change-me
