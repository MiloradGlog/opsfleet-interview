# --- Google AI Studio (Gemini chat + embeddings) ---
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- BigQuery compute (separate auth from the key above) ---
# A billable GCP project (free 1 TB/month tier is plenty). The dataset is public,
# but the query runs in YOUR project. Authenticate with:
#   gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=

# --- Models (current as of 2026-05) ---
GEMINI_MODEL=gemini-3.5-flash
EMBED_MODEL=gemini-embedding-001

# --- Behavior ---
AGENT_USER_ID=manager_a
MAX_SQL_ATTEMPTS=3
MAX_RESULT_ROWS=1000
PREVIEW_ROWS=50
MODEL_RUN_LIMIT=8

# Secret for signing the deletion audit op_id (set to a random value for real use).
HMAC_SECRET=dev-secret-change-me
